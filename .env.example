# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Deepgram API key for voice transcription (console.deepgram.com)
DEEPGRAM_API_KEY=

# Todoist API key for task management (Settings → Integrations)
TODOIST_API_KEY=

# Path to Obsidian vault directory
VAULT_PATH=./vault

# JSON array of Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=[123456]

# Auto-push vault changes to GitHub after processing
GIT_PUSH_ENABLED=true

# Claude subprocess timeout in seconds (default: 1200)
CLAUDE_TIMEOUT=1200

# Deepgram transcription language code (default: ru)
TRANSCRIPTION_LANGUAGE=ru

# Path to Google Calendar OAuth token file
GOOGLE_TOKEN_PATH=~/life-pilot/token.json
