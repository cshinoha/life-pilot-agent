# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Groq API key for voice transcription via Whisper (console.groq.com)
# Replaces Deepgram as the primary transcription backend
GROQ_API_KEY=

# [DEPRECATED] Deepgram API key — kept for backward compatibility only
# New installs should use GROQ_API_KEY instead
DEEPGRAM_API_KEY=

# Relative path inside the vault for TaskNotes markdown task files
TASKNOTES_DIR=TaskNotes/Tasks

# Path to Obsidian vault directory
VAULT_PATH=./vault

# JSON array of Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=[123456789]

# Allow access to all Telegram users (security risk — use only for testing)
ALLOW_ALL_USERS=false

# Auto-push vault changes to GitHub after Claude processing
GIT_PUSH_ENABLED=true

# Claude CLI subprocess timeout in seconds
CLAUDE_TIMEOUT=1200

# Claude model override for Coach Mode (e.g. claude-opus-4-5). Empty = use default model.
COACH_MODEL=

# Transcription language code passed to Groq Whisper (e.g. ru, en, multi)
TRANSCRIPTION_LANGUAGE=ru

# Timezone for APScheduler and date calculations (pytz format)
TIMEZONE=Europe/Kyiv

# Path to Google Calendar OAuth token file (generated by oauth flow)
GOOGLE_TOKEN_PATH=~/life-pilot/token.json
