# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Deepgram API key for voice transcription
DEEPGRAM_API_KEY=

# Todoist API key for task management
TODOIST_API_KEY=

# Path to Obsidian vault directory
VAULT_PATH=./vault

# JSON array of Telegram user IDs allowed to use the bot
# WARNING: empty list [] + ALLOW_ALL_USERS=false = access denied for everyone
ALLOWED_USER_IDS=[123456789]

# Allow ALL users to access the bot (SECURITY RISK — only for testing)
ALLOW_ALL_USERS=false

# Claude subprocess timeout in seconds (default: 1200)
CLAUDE_TIMEOUT=1200

# Deepgram transcription language (default: ru)
TRANSCRIPTION_LANGUAGE=ru

# Model for Coach Mode (default: claude-opus-4-6)
COACH_MODEL=claude-opus-4-6

# Path to Google OAuth token for Calendar integration
GOOGLE_TOKEN_PATH=~/life-pilot/token.json
